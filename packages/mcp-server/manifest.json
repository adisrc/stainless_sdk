{
  "dxt_version": "0.1",
  "name": "test_wiz-mcp",
  "version": "1.0.0",
  "description": "The official MCP Server for the Test Wiz API",
  "author": {
    "name": "Test Wiz",
    "email": "tech@wizcommerce.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adisrc/stainless_sdk.git"
  },
  "homepage": "https://github.com/adisrc/stainless_sdk/tree/main/packages/mcp-server#readme",
  "documentation": "https://help.wizcommerce.com/",
  "server": {
    "type": "node",
    "entry_point": "${__dirname}/index.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/index.js"],
      "env": {
        "TEST_WIZ_API_KEY": "${user_config.TEST_WIZ_API_KEY}"
      }
    }
  },
  "user_config": {
    "TEST_WIZ_API_KEY": {
      "title": "api_key",
      "description": "API Key for authentication",
      "required": true,
      "type": "string"
    }
  },
  "tools_generated": true,
  "compatibility": {
    "runtimes": {
      "node": ">=18.0.0"
    }
  },
  "keywords": ["api"]
}
